{
  "$schema": "https://react.doctor/schema/config.json",
  "rules": {
    "react-doctor/only-export-components": "off",
    "react-doctor/no-multi-comp": "off",
    "react-doctor/require-reduced-motion": "off"
  },
  "ignore": {
    "overrides": [
      {
        "files": ["**/empty-state/assets/**", "**/icons/registry.ts"],
        "rules": ["react-doctor/no-barrel-import"]
      },
      {
        "files": ["**/empty-state/assets/**"],
        "rules": ["react-doctor/no-giant-component"]
      },
      {
        "files": ["**/charts/**"],
        "rules": ["react-doctor/prefer-dynamic-import"]
      },
      {
        "files": ["**/animated-counter/animated-counter.tsx"],
        "rules": [
          "react-doctor/no-adjust-state-on-prop-change",
          "react-doctor/no-cascading-set-state",
          "react-doctor/no-derived-useState",
          "react-doctor/prefer-useReducer"
        ]
      },
      {
        "files": ["**/emoji-icon-picker/icon/icon-root.tsx"],
        "rules": [
          "react-doctor/no-adjust-state-on-prop-change",
          "react-doctor/no-derived-state",
          "react-doctor/prefer-useReducer"
        ]
      },
      {
        "files": ["**/collapsible/collapsible.tsx"],
        "rules": ["react-doctor/no-derived-state", "react-doctor/no-event-handler"]
      },
      {
        "files": ["**/tab-navigation/tab-navigation-item.tsx"],
        "rules": ["react-doctor/use-lazy-motion"]
      },
      {
        "files": ["**/portal/modal-portal.tsx"],
        "rules": [
          "react-doctor/advanced-event-handler-refs",
          "react-doctor/prefer-html-dialog",
          "react-doctor/prefer-tag-over-role"
        ]
      },
      {
        "files": ["**/charts/components/legend.tsx"],
        "rules": ["react-doctor/no-static-element-interactions"]
      }
    ]
  }
}
