{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "forkProcessing": "enabled",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Group React and its type definitions",
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "/^@types/react/"
      ]
    },
    {
      "description": "Group Next.js packages",
      "groupName": "next.js",
      "matchPackageNames": [
        "next",
        "eslint-config-next",
        "/^@next//"
      ]
    },
    {
      "description": "Group the TipTap / ProseMirror editor stack",
      "groupName": "editor (tiptap/prosemirror)",
      "matchPackageNames": [
        "/^@tiptap//",
        "/^prosemirror-/",
        "/^@hocuspocus//",
        "yjs",
        "y-prosemirror"
      ]
    },
    {
      "description": "Group linting and formatting tooling",
      "groupName": "linting",
      "matchPackageNames": [
        "eslint",
        "prettier",
        "/^@typescript-eslint//",
        "/^eslint-/"
      ]
    },
    {
      "description": "Group Storybook packages",
      "groupName": "storybook",
      "matchPackageNames": [
        "storybook",
        "/^@storybook//"
      ]
    },
    {
      "description": "Group TypeScript and related build tooling",
      "groupName": "typescript",
      "matchPackageNames": [
        "typescript",
        "tslib",
        "/^ts-/"
      ]
    },
    {
      "description": "Group all Python (API) dependencies",
      "groupName": "python",
      "matchManagers": [
        "pip_requirements",
        "pip-compile",
        "pep621"
      ]
    },
    {
      "description": "Group GitHub Actions updates",
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": "Group Docker base image updates",
      "groupName": "docker",
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ]
    }
  ]
}
